NEXT_PUBLIC_MONGODB_URI=your_mongodb_connection_string_here

# Contact form → emails to vakulenkoforwork@gmail.com
# --- Option A: Formspree (easiest, no domain) ---
# 1. Go to https://formspree.io and sign up. 2. Create a form, set "Email to" to vakulenkoforwork@gmail.com. 3. Copy the form ID from the endpoint (e.g. https://formspree.io/f/xyzabc → xyzabc).
FORMSPREE_FORM_ID=
# --- Option B: Resend (needs verified domain to send to any email) ---
# Without a verified domain, Resend only sends to the account email (e.g. vsesvit.vip@gmail.com). To send to vakulenkoforwork@gmail.com, verify a domain at resend.com/domains.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=contact@yourdomain.com
# RESEND_FROM_NAME=Portfolio Contact
